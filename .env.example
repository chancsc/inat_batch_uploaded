# --- Option A: Direct API token (simplest) ---
# Get yours at inaturalist.org/users/edit → scroll to "Applications" → API Token
INAT_API_TOKEN=your_jwt_api_token_here

# --- Option B: OAuth2 credentials (only needed if you don't use Option A) ---
# Register an app at https://www.inaturalist.org/oauth/applications/new
INAT_APP_ID=your_oauth_app_id
INAT_APP_SECRET=your_oauth_app_secret
INAT_USERNAME=your_inat_username
INAT_PASSWORD=your_inat_password

# Optional: default path to your YOLO butterfly model weights
YOLO_MODEL_PATH=./butterfly_model.pt
